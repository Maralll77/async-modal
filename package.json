    "@mui/material": "9.0.1",
    "@mui/stylis-plugin-rtl": "9.0.1",
    "@paratco/eslint-config": "3.4.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
