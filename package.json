    "@types/stylis": "4.2.7",
    "@vitejs/plugin-react": "6.0.2",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.37.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "semantic-release": "25.0.3",
    "stylis": "4.4.0",
